<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Uplift" suffix=" · LMS">
      {assigns[:page_title]}
    </.live_title>

    <%!-- Icons --%>
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/images/favicon-16x16.png"} />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/images/favicon-32x32.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/manifest.webmanifest"} />
    <meta name="theme-color" content="#1E1B4B" />

    <%!-- Open Graph / Twitter Card --%>
    <meta property="og:title" content={assigns[:page_title] || "Uplift"} />
    <meta
      property="og:description"
      content="Uplift — modern learning management for modern teams."
    />
    <meta property="og:image" content={url(~p"/images/og-image.png")} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={url(~p"/images/og-image.png")} />

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <%= unless assigns[:hide_root_nav] || assigns[:current_scope] do %>
      <nav class="bg-base-100 border-b border-base-300">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex h-12 items-center justify-between">
          <.link href={~p"/"} class="text-lg font-bold text-primary tracking-tight">
            Uplift
          </.link>
          <div class="flex items-center gap-4">
            <%= if @current_scope do %>
              <span class="text-sm text-base-content/60">{@current_scope.user.email}</span>
              <.link
                href={~p"/users/settings"}
                class="text-sm text-base-content/70 hover:text-primary transition-colors"
              >
                Settings
              </.link>
              <.link
                href={~p"/users/log-out"}
                method="delete"
                class="text-sm text-base-content/70 hover:text-primary transition-colors"
              >
                Log out
              </.link>
            <% else %>
              <.link
                href={~p"/users/log-in"}
                class="text-sm text-base-content/70 hover:text-primary transition-colors"
              >
                Log in
              </.link>
              <.link href={~p"/users/register"} class="btn btn-primary btn-sm">
                Register
              </.link>
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>
    {@inner_content}
  </body>
</html>
